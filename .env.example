# HuggingFace access token with access to pyannote/speaker-diarization-3.1
# Get one at: https://huggingface.co/settings/tokens
# Required for speaker diarization. Without it, /transcribe still works but diarize=true returns 400.
HF_TOKEN=

# Server bind
HOST=0.0.0.0
PORT=8000

# Limits
MAX_AUDIO_DURATION=7200      # seconds (2h)
MAX_FILE_SIZE=524288000      # bytes  (500MB)

# Inference
WHISPER_MODEL=large-v3
COMPUTE_TYPE=float16         # float16 (GPU) | int8_float16 | int8 (CPU)
BEAM_SIZE=5

# Storage
MODEL_DIR=./models
DOWNLOAD_TTL_SECONDS=3600
